# ============================================================
#  SAM 3D Body — Karate Animation Pipeline
#  Copy this file to .env and fill in your API keys
# ============================================================

# Groq API key — used for voice-controlled avatar commands (Llama 3.3 70B)
# Get yours at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# BigModel API key (optional)
BIGMODEL_API_KEY=your_bigmodel_api_key_here

# HuggingFace token — required to download gated SAM 3D Body checkpoints
# Get yours at: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_your_token_here
